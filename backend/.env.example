# Server
PORT=3001
NODE_ENV=development

# Database
# Local: postgresql://postgres:postgres@localhost:5432/support_tickets?schema=public
# Neon:  postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/support_tickets?schema=public"

# CORS — comma-separated for multiple origins (local + Vercel frontend)
CORS_ORIGIN=http://localhost:3000

# Auth (use a strong random secret in production, min 32 chars)
JWT_SECRET=dev-jwt-secret-change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
